# ──────────────────��───────────────────────────────────���───────
# The Treehouse — Environment Variables
#
# Copy this file to .env.local and fill in values.
#
# VITE_ variables are inlined at build time and visible to the
# browser. Server-only variables (no VITE_ prefix) are only
# available to Vercel edge/serverless functions.
# ──────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────��─────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Auth ────────────────────────���───────────────────────────
# Origin for postMessage validation between host and plugin iframes
VITE_PLATFORM_ORIGIN=http://localhost:1212

# JWT secret for signing platform auth tokens — MUST be changed in production
VITE_JWT_SECRET=change-me-in-production

# Access code required to register as a teacher — MUST be changed in production
VITE_TEACHER_CODE=change-me

# ── Claude API proxy (server-side only) ─────────────────────
# Set this in Vercel Dashboard > Environment Variables.
# The edge function at api/claude.ts injects it server-side so
# users on the deployed site don't need their own API key.
# NEVER put this in .env.local or commit it to git.
# ANTHROPIC_API_KEY=sk-ant-...

# ── Plugin URLs (optional) ────────────────────────────────��─
# Defaults to localhost dev servers. Set to production URLs in
# Vercel environment variables for deployed builds.
# VITE_PLUGIN_CHESS_URL=http://localhost:5174
# VITE_PLUGIN_PIXELART_URL=http://localhost:5175
# VITE_PLUGIN_PET_URL=http://localhost:5176
# VITE_PLUGIN_TOKENS_URL=http://localhost:5177
# VITE_PLUGIN_PIONEER_URL=http://localhost:5178
# VITE_PLUGIN_BODY_URL=http://localhost:5179
