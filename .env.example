# ──────────────────────────────────────────────────────────────
# The Treehouse — Environment Variables
#
# Copy this file to .env.local and fill in values.
#
# VITE_ variables are inlined at build time and visible to the
# browser. Server-only variables (no VITE_ prefix) are only
# available to Vercel edge/serverless functions and MUST be used
# for any value that would be unsafe to ship to the client.
# ──────────────────────────────────────────────────────────────

# ── Supabase (client-side) ────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Auth (client-side) ────────────────────────────────────────
# Origin for postMessage validation between host and plugin iframes
VITE_PLATFORM_ORIGIN=http://localhost:1212

# ── Server-side only ──────────────────────────────────────────
# Set these in Vercel Dashboard > Environment Variables.
# NEVER prefix with VITE_ — that would inline them into the
# browser bundle and defeat the entire point.

# Anthropic API key for the Claude proxy at api/claude.ts
# ANTHROPIC_API_KEY=sk-ant-...

# Access code required to claim the teacher role at signup.
# Validated server-side by api/claim-teacher-role.ts.
# TEACHER_CODE=change-me

# Supabase service-role key. Used by api/claim-teacher-role.ts
# to write user_profiles.role, which authenticated clients are
# not permitted to modify directly. Treat this like a root password.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Plugin URLs (optional) ────────────────────────────────────
# Defaults to localhost dev servers. Set to production URLs in
# Vercel environment variables for deployed builds.
# VITE_PLUGIN_CHESS_URL=http://localhost:5174
# VITE_PLUGIN_PIXELART_URL=http://localhost:5175
# VITE_PLUGIN_PET_URL=http://localhost:5176
# VITE_PLUGIN_TOKENS_URL=http://localhost:5177
# VITE_PLUGIN_PIONEER_URL=http://localhost:5178
# VITE_PLUGIN_BODY_URL=http://localhost:5179
