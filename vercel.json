{
  "buildCommand": "cross-env CHATBOX_BUILD_PLATFORM=web electron-vite build",
  "outputDirectory": "release/app/dist/renderer",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
