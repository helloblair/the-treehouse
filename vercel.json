{
  "buildCommand": "cross-env CHATBOX_BUILD_PLATFORM=web electron-vite build",
  "outputDirectory": "release/app/dist/renderer",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/claude.ts": { "maxDuration": 30 },
    "api/claim-teacher-role.ts": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
